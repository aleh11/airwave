{
  "lock": true,
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"]
  },
  "imports": {
    "@astryxdesign/core": "npm:@astryxdesign/core@0.1.6",
    "@astryxdesign/cli": "npm:@astryxdesign/cli@0.1.6",
    "@astryxdesign/theme-neutral": "npm:@astryxdesign/theme-neutral@0.1.6",
    "@astryxdesign/theme-stone": "npm:@astryxdesign/theme-stone@0.1.6",
    "@astryxdesign/theme-y2k": "npm:@astryxdesign/theme-y2k@0.1.6",
    "@stylexjs/stylex": "npm:@stylexjs/stylex@0.19.0",
    "@std/assert": "jsr:@std/assert@^1.0.18",
    "@std/http": "jsr:@std/http@^1.0.21",
    "@std/http/file-server": "jsr:@std/http@^1.0.21/file-server",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@6.0.3",
    "lucide-react": "npm:lucide-react@1.25.0",
    "react": "npm:react@19.2.7",
    "react-dom": "npm:react-dom@19.2.7",
    "vite": "npm:vite@8.1.5"
  },
  "tasks": {
    "dev": "deno run -A scripts/dev.ts",
    "astryx": "deno run -A npm:@astryxdesign/cli@0.1.6",
    "dev:server": "deno run -A --watch backend/main.ts",
    "dev:web": "deno run -A npm:vite@8.1.5 --host 0.0.0.0 web",
    "build": "deno run -A npm:vite@8.1.5 build web",
    "check": "deno fmt --check && deno lint && deno check backend/main.ts web/src/main.tsx",
    "test": "deno test -A",
    "compile": "deno task build && deno compile --target aarch64-unknown-linux-gnu --include web/dist --allow-env --allow-net --allow-read --allow-run --allow-write -o build/airwave-linux-arm64 backend/main.ts",
    "compile:local": "deno task build && deno compile --include web/dist --allow-env --allow-net --allow-read --allow-run --allow-write -o build/airwave backend/main.ts"
  },
  "exclude": ["build", "data", "node_modules", "web/dist"]
}
